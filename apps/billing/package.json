{
  "name": "billing-ui",
  "version": "1.36.13",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "start": "vite --mode $([ \"$ENV\" = \"local\" ] && echo default || echo ${ENV:-default})",
    "build": "tsc && vite build --mode default",
    "build:env": "ENV=$npm_config_env npm run build-skeleton",
    "build:local": "npm run build",
    "build:e2e": "ENV=e2e npm run build-skeleton",
    "build:e2e2": "ENV=e2e2 npm run build-skeleton",
    "build:e2e3": "ENV=e2e3 npm run build-skeleton",
    "build:e2e5": "NODE_OPTIONS=${NODE_OPTIONS:---max-old-space-size=8192} ENV=e2e5 npm run build-skeleton",
    "build:e2e4": "NODE_OPTIONS=${NODE_OPTIONS:---max-old-space-size=8192} ENV=e2e4 npm run build-skeleton",
    "build:development": "ENV=development npm run build-skeleton",
    "build:testing": "ENV=testing npm run build-skeleton",
    "build:staging": "ENV=staging npm run build-skeleton",
    "build:demo": "ENV=demo npm run build-skeleton",
    "build:production": "ENV=production npm run build-skeleton",
    "build-skeleton": "tsc && vite build --mode ${ENV}",
    "lint": "eslint --ext .ts,.tsx --max-warnings 0 ."
  },
  "dependencies": {
    "@mui/icons-material": "^5.14.9",
    "@mui/lab": "^5.0.0-alpha.170",
    "@mui/x-data-grid-pro": "^6.3.0",
    "notistack": "^3.0.1",
    "tsconfig": "*",
    "utils": "*"
  }
}
