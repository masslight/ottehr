{
  "extends": "tsconfig/react.json",
  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext.array", "dom", "es2022"],
    "module": "ESNext",
    "sourceMap": true,
    "inlineSources": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@theme/*": ["./src/themes/ottehr/*"],
      "@defaultTheme/*": ["./src/themes/ottehr/*"],
      "src/*": ["./src/*"],
      "tests/*": ["./tests/*"]
    }
  },
  "include": ["."]
}
