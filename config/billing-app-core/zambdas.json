  "fhirResources": {
    "SUB_PRESUBMISSION_RULES_ENGINE_SUBSCRIPTION": {
      "resource": {
        "resourceType": "Subscription",
        "status": "active",
        "reason": "run billing claim submission rules engine",
        "criteria": "Task?code=https://fhir.ottehr.com/CodeSystem/billing-rules-engine|run-presubmission-rules&status=requested",
        "channel": {
          "type": "rest-hook",
          "endpoint": "zapehr-lambda:#{ref/zambdas/SUB-RULES-ENGINE/id}"
        },
        "extension": [
          {
            "url": "http://zapehr.com/fhir/extension/SubscriptionTriggerEvent",
            "valueString": "create"
          }
        ]
      }
    },
