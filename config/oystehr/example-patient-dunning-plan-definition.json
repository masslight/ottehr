      "id": "action-1",
      "title": "Charge Credit Card on File — Initial Attempt",
      "description": "Attempt to charge the patient's card on file on the invoice due date. Retry 2 times every 3 days.",
      "priority": "routine",
      "code": [
        {
          "coding": [
            {
