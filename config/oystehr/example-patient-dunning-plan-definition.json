          "type": "named-event",
          "name": "invoice-due",
          "condition": {
            "description": "Triggered when the invoice due date is reached",
            "language": "text/fhirpath",
            "expression": "Invoice.date <= today()"
          }
        }
      ],
      "timingTiming": {
        "repeat": {
          "count": 2,
          "frequency": 1,
          "period": 3,
          "periodUnit": "d"
