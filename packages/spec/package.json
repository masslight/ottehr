{
  "name": "spec",
  "version": "1.38.21",
  "description": "Library for interacting with Ottehr spec and var files",
  "scripts": {
    "build": "tsc --noEmit",
    "lint-terraform": "terraform fmt",
    "lint": "oxlint --type-aware --report-unused-disable-directives --deny-warnings .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text-summary --passWithNoTests --reporter=dot --reporter=github-actions",
    "test:watch": "vitest",
    "lint:fix": "oxlint --type-aware --report-unused-disable-directives --deny-warnings --fix ."
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "vitest": "^3.2.4"
  }
}
