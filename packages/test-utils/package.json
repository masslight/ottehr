{
  "name": "test-utils",
  "type": "module",
  "private": true,
  "version": "1.38.12",
  "main": "lib/main.ts",
  "types": "lib/main.ts",
  "exports": {
    ".": "./lib/index.ts",
    "./*": "./lib/*"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint --type-aware --report-unused-disable-directives --deny-warnings .",
    "lint:fix": "oxlint --type-aware --report-unused-disable-directives --deny-warnings --fix .",
    "preview": "vite preview",
    "test": "vitest --silent",
    "test:ci": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text-summary --passWithNoTests --reporter=dot --reporter=github-actions",
    "coverage": "vitest run --coverage",
    "clean-e2e": "tsc scripts/clean-up-e2e.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0"
  },
  "dependencies": {
    "axios": "v1.12.0"
  }
}
