{
  "name": "utils",
  "private": true,
  "type": "module",
  "version": "1.38.12",
  "main": "lib/main.ts",
  "types": "lib/main.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "concurrently --kill-others-on-fail \"tsc\" \"vite build\"",
    "lint": "oxlint --type-aware --report-unused-disable-directives --deny-warnings .",
    "lint:fix": "oxlint --type-aware --report-unused-disable-directives --deny-warnings --fix .",
    "preview": "vite preview",
    "test": "vitest --silent",
    "test:ci": "vitest run --coverage --passWithNoTests --reporter=dot --reporter=github-actions",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lodash-es": "^4.17.21",
    "config-types": "*"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "stripe": "^17.7.0"
  }
}
