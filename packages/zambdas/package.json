    "mock-unsolicited-result": "NODE_OPTIONS='--preserve-symlinks' tsx src/scripts/labs/unsolicited-result-helper.ts",
    "make-in-house-test-items": "NODE_OPTIONS='--preserve-symlinks' tsx src/scripts/labs/load-in-house-labs-tests.ts",
