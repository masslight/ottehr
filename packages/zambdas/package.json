    "mock-attachment-result": "NODE_OPTIONS='--preserve-symlinks' tsx src/scripts/labs/attachment-result-helper.ts",
    "mock-abn-doc": "NODE_OPTIONS='--preserve-symlinks' tsx src/scripts/labs/create-abn-doc.ts",
    "get-lab-sr-dr-docref": "NODE_OPTIONS='--preserve-symlinks' tsx src/scripts/labs/get-external-lab-sr-dr-docref.ts",
