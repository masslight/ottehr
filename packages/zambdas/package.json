    "test:ci": "ENV=${ENV:-local} vitest run --coverage --passWithNoTests --reporter=dot --reporter=github-actions",
    "test:watch": "ENV=${ENV:-local} vitest watch",
    "test:coverage": "c8 npm run test",
    "test:integration:coverage": "ENV=${ENV:-local} c8 --src=src --include='src/**' --exclude='src/**/*.test.ts' --exclude='src/local-server/**' --exclude='src/scripts/**' --all --reporter=text-summary --reporter=lcov --reporter=html --reports-dir=coverage/integration vitest run test/integration/",
