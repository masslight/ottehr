    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/diacritics": "^1.3.3",
    "@types/express": "^5.0.1",
    "@types/luxon": "^3.3.2",
    "@types/pdfmake": "^0.3.2",
    "@types/randomstring": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "esbuild": "^0.25.1",
    "esbuild-plugin-copy": "^2.1.1",
