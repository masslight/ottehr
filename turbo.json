{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["ENV", "PLAYWRIGHT_SUITE_ID", "PLAYWRIGHT_REPORT_SUFFIX", "PLAYWRIGHT_EXTRA_ARGS", "IS_LOGIN_TEST", "INTEGRATION_TEST", "SMOKE_TEST"],
  "tasks": {
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:iac": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".dist/**"]
    },
    "ci-deploy": {
      "dependsOn": ["build", "lint"]
    },
    "ci-deploy:demo": {
      "dependsOn": ["build", "lint"]
    },
    "test": {
      "env": ["ENV"],
      "inputs": [
        "apps/**/*.tsx",
        "apps/**/*.ts",
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx"
      ]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "e2e:login": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "e2e:login:ui": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "e2e:specs:ui": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "e2e:specs": {
      "cache": false,
      "dependsOn": ["^build"]
    }
  }
}
